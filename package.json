{
  "name": "vue-template",
  "version": "0.0.0",
  "description": "A customized Vue.js project template",
  "type": "module",
  "lastDependencyUpdate": "12.03.2026",
  "scripts": {
    "clean:caches": "rm -rf .eslintcache .stylelintcache node_modules/.cache",
    "dev": "vite",
    "fix:stylelint": "npm run lint:stylelint -- --cache=false --config .stylelintrc.fix.js --fix",
    "lint": "npm run lint:eslint && npm run lint:stylelint && npm run tsc",
    "lint:eslint": "eslint ./",
    "lint:stylelint": "stylelint 'src/**/*.?(vue|scss)'",
    "lint-staged": "lint-staged",
    "test": "npm run lint && npm run test:unit -- --watch=false",
    "test:unit": "vitest --dir tests",
    "build": "vite build --mode=app",
    "build:icons": "svg-sprite --config .svg-sprite.json src/assets/icons/*.svg; node ./update-ts-icon-type",
    "build:profile": "npm run build -- --mode=profile",
    "build:watch": "npm run build -- --watch",
    "serve": "vite preview",
    "prepare": "husky",
    "prettier": "prettier . --write",
    "tsc": "vue-tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valantic/vue-template.git"
  },
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "keywords": [
    "vue",
    "vuejs",
    "valantic"
  ],
  "author": "valantic CEC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/valantic/vue-template/issues"
  },
  "homepage": "https://github.com/valantic/vue-template",
  "dependencies": {
    "@valantic/frontend-utils": "github:valantic/frontend-utils#v0.0.1",
    "@valantic/scss-utils": "github:valantic/scss-utils#v1.1.0",
    "@vuelidate/core": "~2.0.3",
    "@vuelidate/validators": "~2.0.4",
    "axios": "~1.13.6",
    "body-scroll-lock": "~4.0.0-beta.0",
    "dayjs": "~1.11.20",
    "embla-carousel": "~8.6.0",
    "embla-carousel-autoplay": "~8.6.0",
    "floating-vue": "~5.2.2",
    "pikaday": "~1.8.2",
    "pinia": "~3.0.4",
    "the-new-css-reset": "~1.11.3",
    "vue": "~3.5.30",
    "vue-i18n": "~11.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.3.5",
    "@eslint/js": "~9.39.4",
    "@faker-js/faker": "~10.3.0",
    "@trivago/prettier-plugin-sort-imports": "~5.2.2",
    "@types/body-scroll-lock": "~3.1.2",
    "@types/cookiebot-sdk": "~2.43.5",
    "@types/google.maps": "~3.58.1",
    "@types/node": "~24.12.0",
    "@types/pikaday": "~1.7.10",
    "@types/resize-observer-browser": "~0.1.11",
    "@valantic/vue-styleguide": "github:valantic/vue-styleguide#v1.1.0",
    "@vitejs/plugin-vue": "~6.0.5",
    "@vue/test-utils": "~2.4.6",
    "autoprefixer": "~10.4.27",
    "cssnano": "~7.1.3",
    "eslint": "~9.39.4",
    "eslint-config-prettier": "~10.1.8",
    "eslint-config-valantic": "~18.1.0",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsdoc": "~62.8.0",
    "eslint-plugin-unicorn": "~63.0.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "~17.4.0",
    "husky": "~9.1.7",
    "jsdom": "~28.1.0",
    "lint-staged": "~16.4.0",
    "msw": "~2.12.11",
    "postcss": "~8.5.8",
    "postcss-html": "~1.8.1",
    "postcss-scss": "~4.0.9",
    "prettier": "~3.8.1",
    "rollup-plugin-visualizer": "~7.0.1",
    "sass": "~1.98.0",
    "stylelint": "~17.4.0",
    "stylelint-config-valantic": "~10.1.0",
    "svg-sprite": "~2.0.4",
    "svgo": "~4.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.57.0",
    "vite": "~7.3.1",
    "vite-plugin-compression": "~0.5.1",
    "vite-plugin-image-optimizer": "~2.0.3",
    "vite-plugin-markdown": "~2.2.0",
    "vitest": "~4.1.0",
    "vue-component-type-helpers": "~3.2.5",
    "vue-eslint-parser": "~10.4.0",
    "vue-router": "~5.0.3",
    "vue-tsc": "~3.2.5"
  },
  "browserslist": [
    "> 2%",
    "last 2 years",
    "not ie_mob > 0",
    "not ie > 0",
    "not dead"
  ],
  "msw": {
    "workerDirectory": "public"
  }
}
